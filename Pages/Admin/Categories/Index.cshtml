@page
@model Recomandare_PC.Pages.Admin.Categories.IndexModel
@{
    ViewData["Title"] = "Categorii";
}

<h2>Categorii</h2>
<a asp-page="Create" class="btn btn-primary mb-3">+ Categorie nouă</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>#</th>
            <th>Nume</th>
            <th>Subcategorii</th>
            <th>Acțiuni</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var cat in Model.Categories)
        {
            <tr>
                <td>@cat.Id</td>
                <td>@cat.Name</td>
                <td>@cat.Subcategories.Count</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@cat.Id" class="btn btn-sm btn-warning">Editează</a>
                    <a asp-page="Delete" asp-route-id="@cat.Id" class="btn btn-sm btn-danger">Șterge</a>
                </td>
            </tr>
        }
    </tbody>
</table>
