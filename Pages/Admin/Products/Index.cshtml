@page
@model Recomandare_PC.Pages.Admin.Products.IndexModel
@{
    ViewData["Title"] = "Produse";
}

<h2>Produse</h2>
<a asp-page="Create" class="btn btn-primary mb-3">+ Produs nou</a>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>#</th>
            <th>Nume</th>
            <th>Categorie</th>
            <th>Subcategorie</th>
            <th>Preț (RON)</th>
            <th>Stoc</th>
            <th>PDF</th>
            <th>Acțiuni</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model.Products)
        {
            <tr>
                <td>@p.Id</td>
                <td>@p.Name</td>
                <td>@p.Category.Name</td>
                <td>@(p.Subcategory?.Name ?? "-")</td>
                <td>@p.Price.ToString("F2")</td>
                <td>@p.StockQuantity</td>
                <td>
                    @if (!string.IsNullOrEmpty(p.PdfPath))
                    {
                        <a href="/@p.PdfPath" target="_blank">Vezi PDF</a>
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </td>
                <td>
                    <a asp-controller="Shop" asp-action="Product" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary" target="_blank">Vezi pagina produs</a>
                    <a asp-page="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-warning">Editează</a>
                    <a asp-page="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-danger">Șterge</a>
                </td>
            </tr>
        }
    </tbody>
</table>
