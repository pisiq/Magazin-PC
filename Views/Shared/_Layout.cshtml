<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — PC Shop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-md navbar-dark bg-dark mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">PC Shop</a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link" asp-controller="Shop" asp-action="Search">Caută Produse</a>
                <a class="nav-link" asp-controller="Shop" asp-action="BuildAssistant">Configurator AI</a>
                <a class="nav-link position-relative" asp-controller="Shop" asp-action="Checkout">
                    Coș
                    @if (ViewBag.CartCount is int count && count > 0)
                    {
                        <span class="badge bg-danger rounded-pill ms-1">@count</span>
                    }
                </a>
                <a class="nav-link" href="/Admin/Products/Index">Admin</a>
            </div>
        </div>
    </nav>

    <div class="container">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
