@model List<Recomandare_PC.Models.CartItem>
@{
    ViewData["Title"] = "Coș și Checkout";
    var total = Model.Sum(c => c.Price);
}

<h2 class="mb-4">Coșul meu</h2>

@if (TempData["OrderConfirmed"] is true)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>Comandă finalizată!</strong> Mulțumim pentru achiziție.
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        Coșul este gol. <a asp-action="Search">Caută produse</a>.
    </div>
}
else
{
    <!-- Cart items -->
    <div class="card mb-4">
        <div class="card-header"><strong>Produse selectate</strong></div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Produs</th>
                        <th>Categorie</th>
                        <th class="text-end">Preț (RON)</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td><span class="badge bg-secondary">@item.CategoryName</span></td>
                            <td class="text-end fw-bold">@item.Price.ToString("F2")</td>
                            <td class="text-end">
                                <form method="post" asp-action="RemoveFromCart" class="d-inline">
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Elimină</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="table-light">
                    <tr>
                        <td colspan="2" class="fw-bold">TOTAL</td>
                        <td class="text-end fw-bold text-primary fs-5">@total.ToString("F2") RON</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <!-- Finalize Order -->
    <div class="d-flex justify-content-between align-items-center">
        <a asp-action="Search" class="btn btn-outline-secondary">Continuă cumpărăturile</a>
        <form method="post" asp-action="FinalizeOrder">
            <button type="submit" class="btn btn-success btn-lg px-5">
                Finalizează Comanda — @total.ToString("F2") RON
            </button>
        </form>
    </div>
}
